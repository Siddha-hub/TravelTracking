{
	"_version": "1.69.0",
	"sap.app": {
		"id": "budgetui",
		"type": "application",
		"i18n": {
			"bundleUrl": "i18n/i18n.properties",
			"supportedLocales": [
				""
			]
		},
		"applicationVersion": {
			"version": "0.0.1"
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"resources": "resources.json",
		"sourceTemplate": {
			"id": "@sap/generator-fiori:lrop",
			"version": "1.22.0",
			"toolsId": "budget-ui-combined-001"
		},
		"dataSources": {
			"mainService": {
				"uri": "/service/TravelRequest/",
				"type": "OData",
				"settings": {
					"annotations": [],
					"odataVersion": "4.0"
				}
			}
		},
		"crossNavigation": {
			"inbounds": {
				"budgetui-display": {
					"semanticObject": "Budget",
					"action": "display",
					"title": "{{appTitle}}",
					"signature": {
						"parameters": {},
						"additionalParameters": "allowed"
					}
				}
			}
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {
			"icon": "",
			"favIcon": "",
			"phone": "",
			"phone@2": "",
			"tablet": "",
			"tablet@2": ""
		},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},
	"sap.ui5": {
		"flexEnabled": true,
		"dependencies": {
			"minUI5Version": "1.132.1",
			"libs": {
				"sap.m": {},
				"sap.ui.core": {},
				"sap.fe.templates": {}
			}
		},
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "budgetui.i18n.i18n",
					"supportedLocales": [
						""
					]
				}
			},
			"": {
				"dataSource": "mainService",
				"preload": true,
				"settings": {
					"operationMode": "Server",
					"autoExpandSelect": true,
					"earlyRequests": true
				}
			},
			"@i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"uri": "i18n/i18n.properties",
				"settings": {
					"supportedLocales": [
						""
					]
				}
			}
		},
		"resources": {
			"css": []
		},
		"routing": {
			"config": {},
			"routes": [
				{
					"pattern": ":?query:",
					"name": "BudgetList",
					"target": "BudgetList"
				},
				{
					"pattern": "TravelBudget({key}):?query:",
					"name": "TravelBudgetObjectPage",
					"target": "TravelBudgetObjectPage"
				}
			],
			"targets": {
				"BudgetList": {
					"type": "Component",
					"id": "BudgetList",
					"name": "sap.fe.templates.ListReport",
					"options": {
						"settings": {
							"contextPath": "/TravelBudget",
							"variantManagement": "Page",
							"navigation": {
								"TravelBudget": {
									"detail": {
										"route": "TravelBudgetObjectPage"
									}
								}
							},
							"views": {
								"paths": [
									{
										"key": "budgetMaintenance",
										"annotationPath": "com.sap.vocabularies.UI.v1.SelectionVariant#BudgetMaintenance",
										"entitySet": "TravelBudget",
										"contextPath": "/TravelBudget"
									},
									{
										"key": "budgetAnalytics",
										"annotationPath": "com.sap.vocabularies.UI.v1.SelectionVariant#BudgetAnalytics",
										"entitySet": "BudgetAnalytics",
										"contextPath": "/BudgetAnalytics"
									}
								]
							},
							"controlConfiguration": {
								"@com.sap.vocabularies.UI.v1.LineItem": {
									"tableSettings": {
										"type": "ResponsiveTable"
									}
								}
							}
						}
					}
				},
				"TravelBudgetObjectPage": {
					"type": "Component",
					"id": "TravelBudgetObjectPage",
					"name": "sap.fe.templates.ObjectPage",
					"options": {
						"settings": {
							"editableHeaderContent": false,
							"contextPath": "/TravelBudget"
						}
					}
				}
			}
		},
		"flexBundle": false
	},
	"sap.cloud": {
		"public": true,
		"service": "sap.travel.tracking"
	},
	"sap.fiori": {
		"registrationIds": [],
		"archeType": "transactional"
	},
	"sap.fe": {
		"app": {
			"enableLazyLoading": true
		}
	}
}